<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Ingredients</title>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        .modal-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.5);
            align-items: center;
            justify-content: center;
            z-index: 100;
        }
        .modal-overlay.is-open { display: flex; }
        .modal-box {
            background: #fff;
            padding: 1.5rem;
            border-radius: 8px;
            box-shadow: 0 8px 24px rgba(0,0,0,0.2);
            min-width: 320px;
            max-width: 480px;
        }
        .modal-box h2 { margin-top: 0; }
        .modal-box label { display: block; margin-top: 0.75rem; }
        .modal-box input, .modal-box textarea {
            width: 100%;
            margin-top: 0.25rem;
            box-sizing: border-box;
        }
        .modal-actions {
            margin-top: 1.25rem;
            display: flex;
            gap: 0.5rem;
            justify-content: flex-end;
        }
        .ingredient-scroll {
            max-height: 400px;
            overflow-y: auto;
            border: 1px solid #ccc;
            padding: 0.5rem;
            margin-top: 1rem;
        }
        #ingredient-list {
            list-style: none;
            padding-left: 0;
            margin: 0;
        }
        #ingredient-list li {
            padding: 0.25rem 0.35rem;
            cursor: pointer;
        }
        #ingredient-list li:hover {
            background: #f0f0f0;
        }
        .no-ingredients {
            cursor: default;
        }
        .search-row {
            margin-top: 0.5rem;
            margin-bottom: 0.5rem;
        }
        .search-row input {
            width: 60%;
            max-width: 320px;
        }
    </style>
</head>
<body>
    <h1>All Ingredients</h1>

    <div class="search-row">
        <label for="ingredient-search">Search ingredients:</label>
        <input id="ingredient-search" type="text" placeholder="Type to filter by name or fact">
        <button type="button" id="open-ingredient-modal">Add new ingredient</button>
    </div>

    <div class="ingredient-scroll">
        <ul id="ingredient-list">
        <% if (typeof ingredients !== 'undefined' && ingredients && ingredients.length) { %>
            <% ingredients.forEach(function(ing) { %>
                <li
                    class="ingredient-item"
                    data-id="<%= ing.ingredient_id %>"
                    data-name="<%= ing.name %>"
                    data-fact-title="<%= ing.fact_title || '' %>"
                    data-fact-content="<%= ing.fact_content || '' %>"
                >
                    <%= ing.name %>
                </li>
            <% }); %>
        <% } else { %>
            <li class="no-ingredients">No ingredients in the database.</li>
        <% } %>
        </ul>
    </div>

    <p>
        <a href="/">Back to Home</a>
        <a href="/recipes">View Recipes</a>
        <a href="/add-recipe">Add a Recipe</a>
    </p>

    <!-- Modal for adding a new ingredient (same fields as add-recipe.ejs) -->
    <div class="modal-overlay" id="ingredient-modal" aria-hidden="true">
        <div class="modal-box" onclick="event.stopPropagation()">
            <h2>Add new ingredient</h2>
            <form id="new-ingredient-form">
                <label for="ing-name">Name</label>
                <input id="ing-name" name="name" type="text" required maxlength="100">

                <label for="ing-fact-title">Fact title (optional)</label>
                <input id="ing-fact-title" name="fact_title" type="text" maxlength="100">

                <label for="ing-fact-content">Fact content (optional)</label>
                <textarea id="ing-fact-content" name="fact_content" rows="3"></textarea>

                <div class="modal-actions">
                    <button type="button" id="close-ingredient-modal">Cancel</button>
                    <button type="submit">Add ingredient</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Modal for viewing/editing a single ingredient -->
    <div class="modal-overlay" id="ingredient-detail-modal" aria-hidden="true">
        <div class="modal-box" onclick="event.stopPropagation()">
            <h2 id="detail-title"></h2>
            <form id="ingredient-edit-form">
                <label for="detail-name">Name</label>
                <input id="detail-name" name="name" type="text" required maxlength="100">

                <label for="detail-fact-title">Fact title (optional)</label>
                <input id="detail-fact-title" name="fact_title" type="text" maxlength="100">

                <label for="detail-fact-content">Fact content (optional)</label>
                <textarea id="detail-fact-content" name="fact_content" rows="3"></textarea>

                <div class="modal-actions">
                    <button type="button" id="detail-delete-btn">Delete ingredient</button>
                    <button type="button" id="detail-cancel-btn">Close</button>
                    <button type="submit" id="detail-save-btn">Edit ingredient</button>
                </div>
            </form>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var searchInput = document.getElementById('ingredient-search');
            var list = document.getElementById('ingredient-list');

            function getItems() {
                return list.querySelectorAll('.ingredient-item');
            }

            // Client-side search over name and fact fields
            if (searchInput) {
                searchInput.addEventListener('input', function () {
                    var query = (this.value || '').toLowerCase();
                    getItems().forEach(function (item) {
                        var name = (item.dataset.name || '').toLowerCase();
                        var factTitle = (item.dataset.factTitle || '').toLowerCase();
                        var factContent = (item.dataset.factContent || '').toLowerCase();
                        if (!query || name.includes(query) || factTitle.includes(query) || factContent.includes(query)) {
                            item.style.display = '';
                        } else {
                            item.style.display = 'none';
                        }
                    });
                });
            }

            // Detail modal logic
            var detailOverlay = document.getElementById('ingredient-detail-modal');
            var detailTitle = document.getElementById('detail-title');
            var detailForm = document.getElementById('ingredient-edit-form');
            var detailNameInput = document.getElementById('detail-name');
            var detailFactTitleInput = document.getElementById('detail-fact-title');
            var detailFactContentInput = document.getElementById('detail-fact-content');
            var detailDeleteBtn = document.getElementById('detail-delete-btn');
            var detailCancelBtn = document.getElementById('detail-cancel-btn');

            var currentIngredientId = null;
            var currentItemElement = null;

            function openDetailModal(item) {
                currentIngredientId = item.dataset.id;
                currentItemElement = item;
                detailTitle.textContent = item.dataset.name || '';
                detailNameInput.value = item.dataset.name || '';
                detailFactTitleInput.value = item.dataset.factTitle || '';
                detailFactContentInput.value = item.dataset.factContent || '';
                detailOverlay.classList.add('is-open');
                detailOverlay.setAttribute('aria-hidden', 'false');
            }

            function closeDetailModal() {
                detailOverlay.classList.remove('is-open');
                detailOverlay.setAttribute('aria-hidden', 'true');
                currentIngredientId = null;
                currentItemElement = null;
                detailForm.reset();
            }

            list.addEventListener('click', function (e) {
                var item = e.target.closest('.ingredient-item');
                if (!item) return;
                openDetailModal(item);
            });

            detailCancelBtn.addEventListener('click', closeDetailModal);
            detailOverlay.addEventListener('click', function (e) {
                if (e.target === detailOverlay) {
                    closeDetailModal();
                }
            });

            detailDeleteBtn.addEventListener('click', function () {
                if (!currentIngredientId || !currentItemElement) return;
                var confirmed = window.confirm('Are you sure you want to delete this ingredient?');
                if (!confirmed) return;

                fetch('/ingredient/delete/' + encodeURIComponent(currentIngredientId), {
                    method: 'DELETE'
                })
                .then(function (res) {
                    if (!res.ok) {
                        return res.text().then(function (t) { throw new Error(t || res.status); });
                    }
                    // Remove the element from the list
                    if (currentItemElement.parentNode) {
                        currentItemElement.parentNode.removeChild(currentItemElement);
                    }
                    // If no ingredients left, show message
                    if (!list.querySelector('.ingredient-item')) {
                        var li = document.createElement('li');
                        li.className = 'no-ingredients';
                        li.textContent = 'No ingredients in the database.';
                        list.appendChild(li);
                    }
                    closeDetailModal();
                })
                .catch(function (err) {
                    alert('Could not delete ingredient: ' + (err.message || 'Unknown error'));
                });
            });

            detailForm.addEventListener('submit', function (e) {
                e.preventDefault();
                if (!currentIngredientId || !currentItemElement) return;

                var fd = new FormData(detailForm);
                var body = new URLSearchParams(fd);

                fetch('/ingredient/edit/' + encodeURIComponent(currentIngredientId), {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: body
                })
                .then(function (res) {
                    if (!res.ok) {
                        return res.text().then(function (t) { throw new Error(t || res.status); });
                    }
                    return res.json();
                })
                .then(function (data) {
                    currentItemElement.dataset.name = data.name || '';
                    currentItemElement.dataset.factTitle = data.fact_title || '';
                    currentItemElement.dataset.factContent = data.fact_content || '';
                    currentItemElement.textContent = data.name || '';
                    detailTitle.textContent = data.name || '';
                    alert('Ingredient updated successfully.');
                })
                .catch(function (err) {
                    alert('Could not update ingredient: ' + (err.message || 'Unknown error'));
                });
            });

            // Add-ingredient modal logic (reuses existing /ingredient/add endpoint)
            var addOverlay = document.getElementById('ingredient-modal');
            var openAddBtn = document.getElementById('open-ingredient-modal');
            var closeAddBtn = document.getElementById('close-ingredient-modal');
            var addForm = document.getElementById('new-ingredient-form');

            function openAddModal() {
                addOverlay.classList.add('is-open');
                addOverlay.setAttribute('aria-hidden', 'false');
            }

            function closeAddModal() {
                addOverlay.classList.remove('is-open');
                addOverlay.setAttribute('aria-hidden', 'true');
                addForm.reset();
            }

            openAddBtn.addEventListener('click', openAddModal);
            closeAddBtn.addEventListener('click', closeAddModal);
            addOverlay.addEventListener('click', function (e) {
                if (e.target === addOverlay) {
                    closeAddModal();
                }
            });

            addForm.addEventListener('submit', function (e) {
                e.preventDefault();
                var fd = new FormData(addForm);
                var body = new URLSearchParams(fd);

                fetch('/ingredient/add', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: body
                })
                .then(function (res) {
                    if (!res.ok) {
                        return res.text().then(function (t) { throw new Error(t || res.status); });
                    }
                    return res.json();
                })
                .then(function (data) {
                    // Remove "no ingredients" message if present
                    var noMsg = list.querySelector('.no-ingredients');
                    if (noMsg) {
                        noMsg.remove();
                    }

                    var li = document.createElement('li');
                    li.className = 'ingredient-item';
                    li.dataset.id = data.ingredient_id;
                    li.dataset.name = data.name || '';
                    li.dataset.factTitle = data.fact_title || '';
                    li.dataset.factContent = data.fact_content || '';
                    li.textContent = data.name || '';

                    list.appendChild(li);
                    closeAddModal();
                })
                .catch(function (err) {
                    alert('Could not add ingredient: ' + (err.message || 'Unknown error'));
                });
            });
        });
    </script>
</body>
</html>

