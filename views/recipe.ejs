<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title><%= recipe.title %> - Recipe</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <h1><%= recipe.title %></h1>
    <table border="1">
        <tr>
            <th>Main Protein</th>
            <td><%= recipe.main_protein %></td>
        </tr>
        <tr>
            <th>Description</th>
            <td><%= recipe.description %></td>
        </tr>
        <tr>
            <th>Prep Time</th>
            <td>
                <% if (recipe.prep_time_mins) { %>
                    <%= recipe.prep_time_mins %> minutes
                <% } else { %>
                    N/A
                <% } %>
            </td>
        </tr>
    </table>

    <% if (typeof ingredients !== 'undefined' && ingredients && ingredients.length > 0) { %>
    <h2>Ingredients</h2>
    <ul>
        <% ingredients.forEach(function(ing) { %>
            <li>
                <%= ing.name %><% if (ing.quantity || ing.unit) { %> — <%= ing.quantity || '' %> <%= ing.unit || '' %><% } %>
                <% if (ing.fact_title || ing.fact_content) { %>
                    <span class="ingredient-fact" title="<%= (ing.fact_title ? ing.fact_title + ': ' : '') + (ing.fact_content || '') %>">ⓘ</span>
                    <small class="ingredient-detail"><% if (ing.fact_title) { %><strong><%= ing.fact_title %>:</strong> <% } %><%= ing.fact_content || '' %></small>
                <% } %>
            </li>
        <% }); %>
    </ul>
    <% } %>

    <br>
    <a href="/recipes">Back to All Recipes</a>
    <br>
    <a href="/">Back to Home</a>
</body>
</html>